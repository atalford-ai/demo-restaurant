---
import config from '../../site.json';
const specials = config.specials;
---
<section id="specials" class="py-24 bg-base-200/50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 px-6 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Limited</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Today's Specials</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">Chef's picks. Get them before they're gone.</p>
    </div>

    <div class="space-y-8 px-6">
      {specials.map((special, i) => (
        <div class:list={["card card-side bg-base-100 shadow-xl overflow-hidden", { "flex-row-reverse": i % 2 !== 0 }]}>
          <figure class="w-1/2 hidden md:block">
            <img
              src={special.image}
              alt={special.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </figure>
          <div class="card-body w-full md:w-1/2 justify-center p-8 lg:p-12">
            {special.badge && (
              <div>
                <span class="badge badge-accent">{special.badge}</span>
              </div>
            )}
            <h3 class="card-title text-2xl lg:text-3xl font-heading">{special.name}</h3>
            <p class="text-base-content/70 text-lg leading-relaxed">{special.description}</p>
            <div class="card-actions justify-between items-center mt-4">
              <span class="text-accent font-heading font-bold text-3xl">${special.price}</span>
              <a href="#contact" class="btn btn-accent">Order Now</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
