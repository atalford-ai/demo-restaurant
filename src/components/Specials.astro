---
import config from '../../site.json';
const specials = config.specials;
---
<section id="specials" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Limited</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Today's Specials</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">Chef's picks. Get them before they're gone.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
      {specials.map((special) => (
        <div class="card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <!-- Image -->
          <div class="relative aspect-square bg-base-300/50 overflow-hidden rounded-t-2xl">
            <img src={special.image} alt={special.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />

            {special.badge && (
              <div class="absolute top-3 left-3">
                <span class="badge badge-accent text-xs font-medium">{special.badge}</span>
              </div>
            )}
          </div>

          <div class="card-body p-6">
            <h3 class="font-heading font-semibold text-xl">{special.name}</h3>
            <p class="text-base-content/60 text-sm leading-relaxed mt-1">{special.description}</p>
            <div class="flex justify-between items-center mt-4">
              <span class="text-accent font-heading font-bold text-2xl">${special.price}</span>
              <a href="#contact" class="btn btn-accent btn-sm">Order Now</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
