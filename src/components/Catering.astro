---
import config from '../../site.json';
---
<section id="catering" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto max-w-5xl">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Info -->
      <div class="fade-in-up">
        <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Catering</span>
        <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6">Let Us Feed<br /><span class="text-accent">Your Crowd</span></h2>
        <p class="text-base-content/70 text-lg leading-relaxed mb-6">
          From corporate lunches to family reunions, weddings to block parties — Flame Kitchen brings the heat to your event. Full-service catering with customizable menus.
        </p>

        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-base-content/70">Custom menus for 20 to 500+ guests</span>
          </div>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-base-content/70">Full setup, serving staff, and cleanup available</span>
          </div>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-base-content/70">Food truck on-site option for outdoor events</span>
          </div>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-base-content/70">Serving the greater Atlanta area</span>
          </div>
        </div>

        <div class="mt-8">
          <div class="bg-base-200 rounded-2xl overflow-hidden border border-base-300/50 aspect-video">
            <img src="https://images.unsplash.com/photo-1565123409695-7b5ef63a2efb?w=800&h=450&fit=crop" alt="Flame Kitchen food truck catering" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="fade-in-up" style="animation-delay: 0.2s;">
        <div class="card bg-base-200 shadow-xl">
          <div class="card-body p-8">
            <h3 class="font-heading font-semibold text-xl mb-6">Request a Quote</h3>
            <form class="space-y-5">
              <div>
                <label class="label text-sm font-medium">Name</label>
                <input type="text" placeholder="Your name" class="input input-bordered w-full bg-base-100 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Email</label>
                <input type="email" placeholder="you@email.com" class="input input-bordered w-full bg-base-100 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Phone</label>
                <input type="tel" placeholder="(555) 000-0000" class="input input-bordered w-full bg-base-100 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Event Type</label>
                <select class="select select-bordered w-full bg-base-100 focus:border-accent">
                  <option disabled selected>Choose event type</option>
                  <option>Corporate Event</option>
                  <option>Wedding</option>
                  <option>Birthday Party</option>
                  <option>Family Reunion</option>
                  <option>Block Party</option>
                  <option>Festival / Pop-Up</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="label text-sm font-medium">Event Date</label>
                  <input type="date" class="input input-bordered w-full bg-base-100 focus:border-accent" />
                </div>
                <div>
                  <label class="label text-sm font-medium">Guest Count</label>
                  <input type="number" placeholder="50" min="10" class="input input-bordered w-full bg-base-100 focus:border-accent" />
                </div>
              </div>
              <div>
                <label class="label text-sm font-medium">Message</label>
                <textarea placeholder="Tell us about your event..." class="textarea textarea-bordered w-full bg-base-100 focus:border-accent h-24"></textarea>
              </div>
              <button type="submit" class="btn btn-accent w-full">
                Send Inquiry
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
