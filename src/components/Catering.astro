---
import config from '../../site.json';
---
<section id="catering" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto max-w-5xl">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Catering</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Let Us Feed <span class="text-accent">Your Crowd</span></h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">From corporate lunches to family reunions — Flame Kitchen brings the heat to your event.</p>
    </div>

    <!-- FAQ Accordion -->
    <div class="max-w-3xl mx-auto mb-16 fade-in-up space-y-3">
      <div class="collapse collapse-arrow bg-base-100 shadow-sm">
        <input type="radio" name="catering-faq" checked />
        <div class="collapse-title text-lg font-heading font-semibold">
          How many guests can you serve?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">We cater events from 20 to 500+ guests. Whether it's an intimate dinner or a massive block party, we've got you covered with custom menus scaled to your needs.</p>
        </div>
      </div>

      <div class="collapse collapse-arrow bg-base-100 shadow-sm">
        <input type="radio" name="catering-faq" />
        <div class="collapse-title text-lg font-heading font-semibold">
          What's included in full-service catering?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">Full setup, professional serving staff, all equipment (chafing dishes, utensils, plates), and complete cleanup after your event. You just show up and eat.</p>
        </div>
      </div>

      <div class="collapse collapse-arrow bg-base-100 shadow-sm">
        <input type="radio" name="catering-faq" />
        <div class="collapse-title text-lg font-heading font-semibold">
          Do you offer a food truck option?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">Yes! Our food truck is available for outdoor events, festivals, and pop-ups. It's a crowd favorite and brings that authentic street-style experience to your venue.</p>
        </div>
      </div>

      <div class="collapse collapse-arrow bg-base-100 shadow-sm">
        <input type="radio" name="catering-faq" />
        <div class="collapse-title text-lg font-heading font-semibold">
          What areas do you serve?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">We serve the greater Atlanta metro area. For events outside the metro, reach out and we'll work something out — good food shouldn't have boundaries.</p>
        </div>
      </div>

      <div class="collapse collapse-arrow bg-base-100 shadow-sm">
        <input type="radio" name="catering-faq" />
        <div class="collapse-title text-lg font-heading font-semibold">
          Can you accommodate dietary restrictions?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">Absolutely. We offer vegetarian, vegan, and gluten-free options. Let us know your needs when requesting a quote and we'll build a menu that works for everyone.</p>
        </div>
      </div>
    </div>

    <!-- Quote Request Form -->
    <div class="max-w-2xl mx-auto fade-in-up">
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body p-8">
          <h3 class="card-title font-heading text-xl mb-6 justify-center">Request a Quote</h3>
          <form class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="label text-sm font-medium">Name</label>
                <input type="text" placeholder="Your name" class="input input-bordered w-full bg-base-200 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Email</label>
                <input type="email" placeholder="you@email.com" class="input input-bordered w-full bg-base-200 focus:border-accent" />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="label text-sm font-medium">Phone</label>
                <input type="tel" placeholder="(555) 000-0000" class="input input-bordered w-full bg-base-200 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Event Type</label>
                <select class="select select-bordered w-full bg-base-200 focus:border-accent">
                  <option disabled selected>Choose event type</option>
                  <option>Corporate Event</option>
                  <option>Wedding</option>
                  <option>Birthday Party</option>
                  <option>Family Reunion</option>
                  <option>Block Party</option>
                  <option>Festival / Pop-Up</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="label text-sm font-medium">Event Date</label>
                <input type="date" class="input input-bordered w-full bg-base-200 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Guest Count</label>
                <input type="number" placeholder="50" min="10" class="input input-bordered w-full bg-base-200 focus:border-accent" />
              </div>
            </div>
            <div>
              <label class="label text-sm font-medium">Message</label>
              <textarea placeholder="Tell us about your event..." class="textarea textarea-bordered w-full bg-base-200 focus:border-accent h-24"></textarea>
            </div>
            <button type="submit" class="btn btn-accent w-full">
              Send Inquiry
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
