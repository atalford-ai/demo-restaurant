---
import config from '../../site.json';
---
<header class="navbar bg-base-100/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-300/50">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl font-heading font-bold tracking-tight">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />
      </svg>
      <span class="text-accent">{config.business_name.split(' ')[0]}</span> {config.business_name.split(' ').slice(1).join(' ')}
    </a>
  </div>

  <nav class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-4">
      <li><a href="#menu" class="font-medium text-base tracking-wide">Menu</a></li>
      <li><a href="#specials" class="font-medium text-base tracking-wide">Specials</a></li>
      <li><a href="#about" class="font-medium text-base tracking-wide">About</a></li>
      <li><a href="#catering" class="font-medium text-base tracking-wide">Catering</a></li>
      <li><a href="#contact" class="font-medium text-base tracking-wide">Contact</a></li>
    </ul>
  </nav>

  <div class="navbar-end gap-2">
    <a href="#menu" class="btn btn-accent btn-sm hidden sm:inline-flex">
      Order Now
    </a>

    <!-- Mobile menu -->
    <div class="dropdown dropdown-end lg:hidden">
      <label tabindex="0" class="btn btn-ghost btn-circle">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-lg bg-base-200 rounded-box w-52">
        <li><a href="#menu">Menu</a></li>
        <li><a href="#specials">Specials</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#catering">Catering</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>
  </div>
</header>
