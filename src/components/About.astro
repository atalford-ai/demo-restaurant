---
import config from '../../site.json';
---
<section id="about" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto max-w-5xl">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Our Story</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Born from the <span class="text-accent">Flame</span></h2>
    </div>

    <!-- Stats -->
    <div class="flex justify-center mb-16 fade-in-up">
      <div class="stats stats-vertical md:stats-horizontal shadow bg-base-200">
        <div class="stat">
          <div class="stat-title">Years Cooking</div>
          <div class="stat-value text-accent">5+</div>
          <div class="stat-desc">Since 2021</div>
        </div>
        <div class="stat">
          <div class="stat-title">Plates Served</div>
          <div class="stat-value text-accent">50K+</div>
          <div class="stat-desc">And counting</div>
        </div>
        <div class="stat">
          <div class="stat-title">Star Rating</div>
          <div class="stat-value text-accent">4.8</div>
          <div class="stat-desc">On Google & Yelp</div>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="fade-in-up">
      <ul class="timeline timeline-vertical timeline-snap-icon">
        <li>
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-accent">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="timeline-start md:text-end mb-10">
            <time class="font-mono italic text-accent">2021</time>
            <div class="text-lg font-heading font-bold">The Food Truck Era</div>
            <p class="text-base-content/70">Started as a weekend food truck on the streets of Atlanta with one grill, one mission: bring real soul food to the people.</p>
          </div>
          <hr class="bg-accent" />
        </li>
        <li>
          <hr class="bg-accent" />
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-accent">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="timeline-end mb-10">
            <time class="font-mono italic text-accent">2022</time>
            <div class="text-lg font-heading font-bold">Pop-Up to Phenomenon</div>
            <p class="text-base-content/70">Word spread fast. Weekend pop-ups turned into weekly sellouts. The community demanded more.</p>
          </div>
          <hr class="bg-accent" />
        </li>
        <li>
          <hr class="bg-accent" />
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-accent">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="timeline-start md:text-end mb-10">
            <time class="font-mono italic text-accent">2023</time>
            <div class="text-lg font-heading font-bold">Brick & Mortar</div>
            <p class="text-base-content/70">Opened our first permanent location on Peachtree St. Same fire, bigger kitchen, more soul.</p>
          </div>
          <hr class="bg-accent" />
        </li>
        <li>
          <hr class="bg-accent" />
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-accent">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="timeline-end mb-10">
            <time class="font-mono italic text-accent">Today</time>
            <div class="text-lg font-heading font-bold">Feeding the Community</div>
            <p class="text-base-content/70">50,000+ plates served, catering across Atlanta, and still cooking with the same passion and recipes passed down through generations.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
