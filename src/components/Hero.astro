---
import config from '../../site.json';
---
<section class="hero min-h-[90vh]" style="background-image: url('https://images.unsplash.com/photo-1544025162-d76694265947?w=1600&h=900&fit=crop');">
  <div class="hero-overlay bg-gradient-to-t from-base-100 via-base-100/70 to-transparent"></div>
  <div class="hero-content text-center py-24">
    <div class="max-w-2xl fade-in-up">
      <span class="badge badge-accent text-xs tracking-widest uppercase mb-6">Now Serving</span>
      <h1 class="text-5xl md:text-7xl font-heading font-bold leading-tight mb-6 text-base-content">
        {config.tagline}
      </h1>
      <p class="text-lg text-base-content/70 max-w-lg mx-auto mb-10">
        {config.description}
      </p>
      <a href="#menu" class="btn btn-primary btn-lg px-10">
        Order Now
      </a>
    </div>
  </div>
</section>
