---
import config from '../../site.json';
const menuCategories = config.menu;

// Dietary/spice badges for items (based on item characteristics)
function getBadges(item: { name: string; description: string }) {
  const badges: { label: string; class: string }[] = [];
  const desc = item.description.toLowerCase();
  const name = item.name.toLowerCase();
  if (desc.includes('spice') || desc.includes('jerk') || desc.includes('cajun') || desc.includes('pepper') || desc.includes('spicy')) {
    badges.push({ label: 'Spicy', class: 'badge-error' });
  }
  if (desc.includes('vegan') || name.includes('plantain') || name.includes('collard') || name.includes('cornbread')) {
    badges.push({ label: 'Veggie', class: 'badge-success' });
  }
  if (desc.includes('gluten') || name.includes('catfish') || name.includes('oxtail')) {
    badges.push({ label: 'GF', class: 'badge-info' });
  }
  return badges;
}
---
<section id="menu" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">The Menu</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">What We're Serving</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">Bold flavors, honest food. Every plate tells a story.</p>
    </div>

    <!-- Tabs -->
    <div class="flex justify-center mb-12">
      <div role="tablist" class="tabs tabs-boxed bg-base-200 p-1">
        {menuCategories.map((cat, i) => (
          <button
            role="tab"
            class:list={["tab font-medium text-sm", "menu-tab", { "tab-active": i === 0 }]}
            data-category={cat.category}
          >
            {cat.category}
          </button>
        ))}
      </div>
    </div>

    <!-- Menu Items -->
    {menuCategories.map((cat, i) => (
      <div
        class:list={["menu-panel grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto", { "hidden": i !== 0 }]}
        data-panel={cat.category}
      >
        {cat.items.map((item) => (
          <div class="card card-compact bg-base-200 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
            <div class="card-body">
              <div class="flex justify-between items-start gap-3">
                <h3 class="card-title text-base font-heading font-semibold">{item.name}</h3>
                <span class="text-accent font-heading font-bold text-lg whitespace-nowrap">${item.price}</span>
              </div>
              <p class="text-base-content/60 text-sm leading-relaxed">{item.description}</p>
              {getBadges(item).length > 0 && (
                <div class="card-actions mt-2">
                  {getBadges(item).map((b) => (
                    <span class={`badge badge-sm ${b.class}`}>{b.label}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<script is:inline>
(function() {
  var tabs = document.querySelectorAll('.menu-tab');
  var panels = document.querySelectorAll('.menu-panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var category = this.dataset.category;

      // Update active tab
      tabs.forEach(function(t) { t.classList.remove('tab-active'); });
      this.classList.add('tab-active');

      // Show matching panel
      panels.forEach(function(p) {
        if (p.dataset.panel === category) {
          p.classList.remove('hidden');
        } else {
          p.classList.add('hidden');
        }
      });
    });
  });
})();
</script>
